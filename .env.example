# =============================================================================
# ENVIRONMENT VARIABLES — Neural AI Hiring System
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Dashboard: https://supabase.com/dashboard/project/<your-project>
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Service role key — server-side only, never expose to the browser
# Settings → API → Service role secret
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Database connection strings
# Settings → Database → Connection string
#
# HOW THESE WORK:
#   DATABASE_URL  — used by the app at runtime for all queries
#   DIRECT_URL    — used only by "prisma migrate dev" for schema changes
#
# FOR DEVELOPMENT (one developer, local machine):
#   Set both to the "Direct connection" URL from the Supabase dashboard.
#   Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
#
# FOR PRODUCTION (Vercel, many concurrent users):
#   DATABASE_URL → Enable Connection Pooling in Supabase dashboard first,
#                  then copy the "Transaction mode" URL (port 6543).
#                  This lets thousands of serverless requests share a small
#                  pool of real database connections instead of each opening
#                  their own — prevents Postgres from running out of connections.
#   DIRECT_URL   → Keep as the direct connection URL (port 5432).
#                  Prisma migrations always need a direct line.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Google Gemini API
# https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Resend (email delivery)
# https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Tavily (web enrichment / LinkedIn research)
# https://app.tavily.com/home
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-...

# -----------------------------------------------------------------------------
# GitHub API (candidate profile enrichment — no scopes needed)
# https://github.com/settings/tokens
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_...

# -----------------------------------------------------------------------------
# Slack
# https://api.slack.com/apps → your app → OAuth & Permissions
# -----------------------------------------------------------------------------
SLACK_APP_TOKEN=xapp-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_HR_CHANNEL_ID=C...
SLACK_INVITE_LINK=https://join.slack.com/t/...

# -----------------------------------------------------------------------------
# Google Calendar (interview scheduling)
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client
# Set USE_MOCK_CALENDAR=true to skip real Google auth during development.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
USE_MOCK_CALENDAR=true
# Default interviewer email for mock slot generation
INTERVIEWER_EMAIL=interviewer@niural.com
# 32-byte hex key for token encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
GOOGLE_TOKENS_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Fireflies (interview notetaker / transcript)
# https://app.fireflies.ai/developer
# Set USE_MOCK_NOTETAKER=true to use a fake transcript during development.
# -----------------------------------------------------------------------------
FIREFLIES_API_KEY=
FIREFLIES_WEBHOOK_SECRET=
USE_MOCK_NOTETAKER=true

# -----------------------------------------------------------------------------
# Auth & Security secrets
# Generate each with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=
ADMIN_SECRET=
OFFER_SIGNING_SECRET=
CRON_SECRET=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
